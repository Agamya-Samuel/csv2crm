# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/csv2crm

# Redis
REDIS_URL=redis://localhost:6379

# AI Provider
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=sk-or-your-key-here
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
XIAOMIMIMO_API_KEY=

# Xiaomi MiMo live balance (optional — paste browser cookie from platform.xiaomimimo.com)
MIMO_COOKIE=

# Processing
BATCH_SIZE=20
BATCH_CONCURRENCY=3
MAX_RETRIES=3

# App
PORT=3001
FRONTEND_URL=http://localhost:3000

# Frontend (set to your deployed API URL in production, e.g. https://api.your-domain.com)
NEXT_PUBLIC_API_URL=http://localhost:3001
